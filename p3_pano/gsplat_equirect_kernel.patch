+// ----------------------------------------------------------------------------
+// EQUIRECTANGULAR (panorama) projection (T-F8). View-space convention matches
+// OmniGS auxiliary.h point3ToLonlatPixel: lon=atan2(x,z), lat=asin(y/r),
+// px=(lon/pi+1)*W/2, py=(lat/(pi/2)+1)*H/2. fx/fy/cx/cy are unused.
+// ----------------------------------------------------------------------------
+#define GS_EQ_PI 3.14159265358979323846f
+
+inline __device__ void equirect_proj(
+    const vec3 mean3d,
+    const mat3 cov3d,
+    const float fx,
+    const float fy,
+    const float cx,
+    const float cy,
+    const uint32_t width,
+    const uint32_t height,
+    mat2 &cov2d,
+    vec2 &mean2d
+) {
+    float x = mean3d[0], y = mean3d[1], z = mean3d[2];
+    const float eps = 1e-7f;
+    float r2 = x * x + y * y + z * z + eps;
+    float r = sqrtf(r2);
+    float rho2 = x * x + z * z + eps;
+    float rho = sqrtf(rho2);
+    float lon = atan2f(x, z);
+    float lat = asinf(fminf(fmaxf(y / r, -0.999999f), 0.999999f));
+    float cwl = (float)width / (2.f * GS_EQ_PI);
+    float chl = (float)height / GS_EQ_PI;
+    mean2d = vec2({(lon / GS_EQ_PI + 1.f) * (0.5f * (float)width),
+                  (lat / (0.5f * GS_EQ_PI) + 1.f) * (0.5f * (float)height)});
+    // mat3x2 = 3 columns (x,y,z) x 2 rows (px,py)
+    mat3x2 J = mat3x2(
+        cwl * z / rho2,            // d px/dx  (col0 row0)
+        -chl * x * y / (rho * r2), // d py/dx  (col0 row1)
+        0.f,                       // d px/dy  (col1 row0)
+        chl * rho / r2,            // d py/dy  (col1 row1)
+        -cwl * x / rho2,           // d px/dz  (col2 row0)
+        -chl * z * y / (rho * r2)  // d py/dz  (col2 row1)
+    );
+    cov2d = J * cov3d * glm::transpose(J);
+}
+
+inline __device__ void equirect_proj_vjp(
+    const vec3 mean3d,
+    const mat3 cov3d,
+    const float fx,
+    const float fy,
+    const float cx,
+    const float cy,
+    const uint32_t width,
+    const uint32_t height,
+    const mat2 v_cov2d,
+    const vec2 v_mean2d,
+    vec3 &v_mean3d,
+    mat3 &v_cov3d
+) {
+    float x = mean3d[0], y = mean3d[1], z = mean3d[2];
+    const float eps = 1e-7f;
+    float r2 = x * x + y * y + z * z + eps;
+    float rho2 = x * x + z * z + eps;
+    float rho = sqrtf(rho2);
+    float cwl = (float)width / (2.f * GS_EQ_PI);
+    float chl = (float)height / GS_EQ_PI;
+
+    float J00 = cwl * z / rho2;             // d px/dx
+    float J01 = -chl * x * y / (rho * r2);  // d py/dx
+    float J11 = chl * rho / r2;             // d py/dy
+    float J20 = -cwl * x / rho2;            // d px/dz
+    float J21 = -chl * z * y / (rho * r2);  // d py/dz
+    // (J10 = d px/dy = 0)
+
+    // 1) grad of mean2d through J: v_mean3d += J^T v_mean2d
+    v_mean3d += vec3(
+        J00 * v_mean2d[0] + J01 * v_mean2d[1],
+        0.f * v_mean2d[0] + J11 * v_mean2d[1],
+        J20 * v_mean2d[0] + J21 * v_mean2d[1]
+    );
+
+    mat3x2 J = mat3x2(J00, J01, 0.f, J11, J20, J21);
+    // 2) grad of cov2d through cov3d: v_cov3d += J^T v_cov2d J
+    v_cov3d += glm::transpose(J) * v_cov2d * J;
+    // 3) grad of cov2d through J(mean3d): v_J then contract with dJ/dmean3d
+    mat3x2 v_J = v_cov2d * J * glm::transpose(cov3d) +
+                 glm::transpose(v_cov2d) * J * cov3d;
+
+    float rho4 = rho2 * rho2;
+    float r4 = r2 * r2;
+    float D = rho * r2, D2 = D * D;
+    float dDdx = x * (r2 + 2.f * rho2) / rho;
+    float dDdy = 2.f * rho * y;
+    float dDdz = z * (r2 + 2.f * rho2) / rho;
+
+    // d(px-row J)/d(.) : depends only on x,z
+    float dJ00dx = -2.f * cwl * x * z / rho4;
+    float dJ00dz = cwl * (x * x - z * z) / rho4;
+    float dJ20dx = cwl * (x * x - z * z) / rho4;
+    float dJ20dz = 2.f * cwl * x * z / rho4;
+    // d(py-row J)/d(.)
+    float dJ01dx = -chl * y / D + chl * x * y * dDdx / D2;
+    float dJ01dy = -chl * x / D + chl * x * y * dDdy / D2;
+    float dJ01dz = chl * x * y * dDdz / D2;
+    float dJ21dx = chl * z * y * dDdx / D2;
+    float dJ21dy = -chl * z / D + chl * z * y * dDdy / D2;
+    float dJ21dz = -chl * y / D + chl * z * y * dDdz / D2;
+    float dJ11dx = chl * x * (1.f / (rho * r2) - 2.f * rho / r4);
+    float dJ11dy = -2.f * chl * rho * y / r4;
+    float dJ11dz = chl * z * (1.f / (rho * r2) - 2.f * rho / r4);
+
+    // contract dJ[col][row]/d(.) with v_J[col][row]
+    float dLdx = dJ00dx * v_J[0][0] + dJ01dx * v_J[0][1] +
+                 dJ11dx * v_J[1][1] + dJ20dx * v_J[2][0] + dJ21dx * v_J[2][1];
+    float dLdy = dJ01dy * v_J[0][1] + dJ11dy * v_J[1][1] + dJ21dy * v_J[2][1];
+    float dLdz = dJ00dz * v_J[0][0] + dJ01dz * v_J[0][1] +
+                 dJ11dz * v_J[1][1] + dJ20dz * v_J[2][0] + dJ21dz * v_J[2][1];
+    v_mean3d.x += dLdx;
+    v_mean3d.y += dLdy;
+    v_mean3d.z += dLdz;
+}
+
 inline __device__ vec3 safe_normalize(vec3 v) {
     const float l = v.x * v.x + v.y * v.y + v.z * v.z;
     return l > 0.0f ? (v * rsqrtf(l)) : v;
